      "name": "Parse Transcript Text"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n  const text = item.json.data;\n\n  const result = {\n    company_name: null,\n    services: [],\n    business_hours: null\n  };\n\n  // extract company name\n  const companyMatch = text.match(/Company:\\s*(.*)/i);\n  if (companyMatch) {\n    result.company_name = companyMatch[1].trim();\n  }\n\n  // extract services\n  if (text.toLowerCase().includes(\"residential\")) {\n    result.services.push(\"Residential electrical work\");\n  }\n  if (text.toLowerCase().includes(\"commercial\")) {\n    result.services.push(\"Commercial electrical work\");\n  }\n  if (text.toLowerCase().includes(\"emergency\")) {\n    result.services.push(\"Emergency service calls\");\n  }\n\n  // extract business hours\n  const hoursMatch = text.match(/Business hours:\\s*(.*)/i);\n  if (hoursMatch) {\n    result.business_hours = hoursMatch[1];\n  } else {\n    result.business_hours = \"Not specified\";\n  }\n\n  return { json: result };\n\n});"
      },
