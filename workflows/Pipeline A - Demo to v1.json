      "parameters": {
        "jsCode": "return items.map(item => {\n\n  const company = (item.json.company_name || \"unknown\")\n    .toLowerCase()\n    .replace(/[^a-z0-9 ]/g, \"\")\n    .replace(/\\s+/g, \"-\");\n\n  const path = `/home/node/.n8n-files/outputs/accounts/${company}/v1/account_memo_v1.json`;\n\n  const jsonString = JSON.stringify(item.json, null, 2);\n\n  return {\n    json: {\n      filePath: path\n    },\n    binary: {\n      data: {\n        data: Buffer.from(jsonString).toString('base64'),\n        mimeType: 'application/json',\n        fileName: 'account_memo_v1.json'\n      }\n    }\n  };\n\n});"
      },
